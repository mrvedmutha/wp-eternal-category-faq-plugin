<?xml version="1.0"?>
<ruleset name="Eternal Product Category FAQ">
	<description>PHPCS coding standards for the eternal-product-category-faq plugin.</description>

	<file>eternal-product-category-faq.php</file>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<config name="minimum_supported_wp_version" value="6.4"/>
	<config name="testVersion" value="8.3-"/>

	<rule ref="WordPress">
		<!-- Class filenames checked by our own convention, not WP convention -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<!-- We use inc/ prefix instead of class- prefix -->
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

</ruleset>
